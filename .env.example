ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email settings
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_USERNAME=user
EMAIL_PASSWORD=password
EMAIL_FROM=user@example.com