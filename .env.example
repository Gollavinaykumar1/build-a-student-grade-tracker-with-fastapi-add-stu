# Database settings
DATABASE_URL=postgresql://user:password@localhost:5432/database
DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_NAME=database
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Redis settings
